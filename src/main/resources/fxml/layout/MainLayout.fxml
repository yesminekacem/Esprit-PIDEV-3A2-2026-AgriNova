<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.layout.controller.MainLayoutController">

    <left>
        <VBox spacing="10" prefWidth="200" style="-fx-padding: 15;">
            <Label text="Digital Farm" style="-fx-font-size: 18px;"/>
            <Button text="Dashboard" onAction="#handleOpenDashboard"/>
            <Button text="Users" onAction="#handleOpenUsers"/>
            <Button text="Crops" onAction="#handleOpenCrops"/>
            <Button text="Inventory" onAction="#handleOpenInventory"/>
            <Button text="Marketplace" onAction="#handleOpenMarketplace"/>
            <Button text="Forum" onAction="#handleOpenForum"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="centerContent">
            <Label text="Welcome to Digital Farm System"/>
        </StackPane>
    </center>

</BorderPane>
