<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.navigation.MainLayoutController"
            styleClass="app-root">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260">

            <!-- Logo -->
            <HBox styleClass="sidebar-header" spacing="12">
                <StackPane styleClass="logo-badge">
                    <Label text="" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="Digital Farm" styleClass="logo-title"/>
                    <Label text="Management System" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox styleClass="nav" spacing="6">
                <Button text="Dashboard" styleClass="nav-item" onAction="#openDashboard"/>
                <Button text="Users" styleClass="nav-item" onAction="#openUsers"/>
                <Button text="Crops" styleClass="nav-item" onAction="#openCrops"/>
                <Button text="Inventory" styleClass="nav-item" onAction="#openInventory"/>
                <Button text="Marketplace" styleClass="nav-item" onAction="#openMarketplace"/>
                <Button text="Forum" styleClass="nav-item" onAction="#openForum"/>
                <Button text="Settings" styleClass="nav-item" onAction="#openSettings"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom Card -->
            <VBox styleClass="pro-card" spacing="10">
                <HBox spacing="10">
                    <StackPane styleClass="pro-icon">
                        <Label text=""/>
                    </StackPane>
                    <VBox>
                        <Label text="Pro Plan" styleClass="pro-title"/>
                        <Label text="Unlock premium features for your farm"
                               wrapText="true"
                               styleClass="pro-text"/>
                    </VBox>
                </HBox>
                <Button text="Upgrade Now" styleClass="btn-primary"/>
            </VBox>

        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" spacing="16" alignment="CENTER_LEFT">

            <HBox styleClass="search-wrap" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="" styleClass="search-icon"/>
                <TextField promptText="Search crops, inventory, orders..."
                           styleClass="search-input"
                           HBox.hgrow="ALWAYS"/>
            </HBox>

            <Button text="" styleClass="icon-btn"/>

            <MenuButton text="John Farmer ▾" styleClass="profile-btn">
                <items>
                    <MenuItem text="Profile"/>
                    <MenuItem text="Billing"/>
                    <MenuItem text="Team"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Log out"/>
                </items>
            </MenuButton>

        </HBox>
    </top>

    <!-- CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <Label text="Welcome to Digital Farm System" styleClass="welcome"/>
        </StackPane>
    </center>

</BorderPane>
