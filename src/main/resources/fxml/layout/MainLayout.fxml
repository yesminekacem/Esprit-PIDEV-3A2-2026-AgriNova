<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.navigation.MainLayoutController"
            styleClass="app-root"
            stylesheets="@/styles/styles.css">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260">

            <!-- Logo -->
            <HBox styleClass="sidebar-header" spacing="12">
                <StackPane styleClass="logo-badge">
                    <Label text="🍃" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="AgriNova" styleClass="logo-title"/>
                    <Label text="Management System" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox styleClass="nav" spacing="6">

                <Button text="Crops" styleClass="nav-item" onAction="#openCrops"/>

                <Button text="Marketplace" styleClass="nav-item" onAction="#openMarketplace"/>


                <Button  text="inventory" onAction="#showInventory"
                        styleClass="nav-button">

                </Button>

                <!-- ONLY FORUM HAS ACTION -->
                <Button text="Forum" styleClass="nav-item" onAction="#openForum"/>

                <!-- Settings should open the user dashboard -->
                <Button text="Settings" styleClass="nav-item" onAction="#openSettings"/>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom Card -->
            <VBox styleClass="pro-card" spacing="10">
                <HBox spacing="10">
                    <StackPane styleClass="pro-icon">
                        <Label text="🌱"/>
                    </StackPane>
                    <VBox>
                        <Label text="Pro Plan" styleClass="pro-title"/>
                        <Label text="Unlock premium features for your farm"
                               wrapText="true"
                               styleClass="pro-text"/>
                    </VBox>
                </HBox>
                <Button text="Upgrade Now" styleClass="btn-primary"/>
            </VBox>

        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" spacing="12" alignment="CENTER_LEFT">

            <!-- Profile section -->
            <HBox spacing="10" alignment="CENTER" styleClass="topbar-profile">
                <StackPane styleClass="topbar-avatar">
                    <Label text="👤" style="-fx-font-size: 18px;"/>
                </StackPane>
                <VBox spacing="1" alignment="CENTER_LEFT">
                    <Label fx:id="profileMenu" text="My Account"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Label text="User" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                </VBox>
            </HBox>

            <!-- Divider -->
            <Separator orientation="VERTICAL" style="-fx-padding: 4 0;"/>

            <!-- Settings -->
            <Button text="⚙ Settings" onAction="#openSettings" styleClass="topbar-action-btn"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Logout -->
            <Button text="⏻ Logout" onAction="#handleLogout" styleClass="topbar-logout-btn"/>

        </HBox>
    </top>

    <!-- CONTENT -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <Label text="Welcome to AgriNova"
                   styleClass="welcome"/>
        </StackPane>
    </center>

</BorderPane>
