<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.user.controller.UserDashboardController"
      style="-fx-background-color:#f0f4f8;"
      spacing="0">

    <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">

        <ScrollPane fitToWidth="true" fitToHeight="false"
                    style="-fx-background-color:transparent;-fx-background:transparent;"
                    VBox.vgrow="ALWAYS">

            <VBox spacing="24" style="-fx-padding:28 32 32 32;">

                <!-- ══ Page header ══ -->
                <VBox spacing="2">
                    <Label text="Account Settings"
                           style="-fx-font-size:26px;-fx-font-weight:800;-fx-text-fill:#0f172a;"/>
                    <Label text="Manage your personal information, security and Face ID."
                           style="-fx-font-size:13px;-fx-text-fill:#64748b;"/>
                </VBox>

                <!-- ══ Top row: Avatar card + Quick-info cards ══ -->
                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- Avatar card -->
                    <VBox spacing="14" alignment="CENTER"
                          style="-fx-background-color:white;-fx-background-radius:16;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),20,0,0,4);
                                 -fx-min-width:200;-fx-max-width:200;-fx-padding:28 20;">
                        <StackPane alignment="CENTER">
                            <Circle radius="52"
                                    style="-fx-fill:linear-gradient(to bottom right,#2E7D32,#66BB6A);"/>
                            <ImageView fx:id="profileImageView" fitWidth="104" fitHeight="104"
                                       preserveRatio="true"
                                       style="-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),8,0,0,2);"/>
                        </StackPane>
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="nameLabel" text="User Name"
                                   style="-fx-font-size:15px;-fx-font-weight:800;-fx-text-fill:#0f172a;"/>
                            <Label fx:id="roleValueLabel" text="USER"
                                   style="-fx-font-size:11px;-fx-font-weight:700;-fx-text-fill:white;
                                          -fx-background-color:#2E7D32;-fx-background-radius:20;
                                          -fx-padding:2 10;"/>
                        </VBox>
                        <Button fx:id="changePicButton" text="📷  Change Photo"
                                onAction="#handleChangePicture"
                                style="-fx-background-color:#f1f5f9;-fx-text-fill:#374151;
                                       -fx-background-radius:10;-fx-padding:7 14;-fx-cursor:hand;
                                       -fx-font-size:12px;-fx-font-weight:700;"/>
                    </VBox>

                    <!-- Quick-info chips -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <!-- Welcome banner -->
                        <HBox alignment="CENTER_LEFT" spacing="0"
                              style="-fx-background-color:linear-gradient(to right,#1b5e20,#2E7D32);
                                     -fx-background-radius:14;-fx-padding:20 24;">
                            <VBox spacing="4">
                                <Label fx:id="welcomeLabel" text="Welcome back!"
                                       style="-fx-font-size:20px;-fx-font-weight:800;-fx-text-fill:white;"/>
                                <Label text="Your profile is up to date."
                                       style="-fx-font-size:13px;-fx-text-fill:rgba(255,255,255,0.80);"/>
                            </VBox>
                        </HBox>

                        <!-- Email + role info row -->
                        <HBox spacing="14">
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:14 18;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,2);">
                                <Label text="📧  Email"
                                       style="-fx-font-size:11px;-fx-font-weight:700;-fx-text-fill:#94a3b8;"/>
                                <Label fx:id="emailValueLabel" text="user@email.com"
                                       style="-fx-font-size:14px;-fx-font-weight:600;-fx-text-fill:#0f172a;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:14 18;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),12,0,0,2);">
                                <Label text="👥  Role"
                                       style="-fx-font-size:11px;-fx-font-weight:700;-fx-text-fill:#94a3b8;"/>
                                <Label fx:id="roleChipLabel" text="User"
                                       style="-fx-font-size:14px;-fx-font-weight:600;-fx-text-fill:#0f172a;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ══ Profile info card ══ -->
                <VBox spacing="0"
                      style="-fx-background-color:white;-fx-background-radius:16;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),20,0,0,4);">
                    <!-- Card header -->
                    <HBox style="-fx-background-color:#f8fafc;-fx-background-radius:16 16 0 0;
                                 -fx-padding:16 24;-fx-border-color:#e2e8f0;
                                 -fx-border-width:0 0 1 0;">
                        <Label text="✏️  Personal Information"
                               style="-fx-font-size:15px;-fx-font-weight:800;-fx-text-fill:#0f172a;"/>
                    </HBox>
                    <VBox spacing="16" style="-fx-padding:22 24;">
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Full Name"
                                       style="-fx-font-size:12px;-fx-font-weight:700;-fx-text-fill:#64748b;"/>
                                <TextField fx:id="fullNameField" promptText="Your full name"
                                           style="-fx-background-color:#f8fafc;-fx-background-radius:10;
                                                  -fx-border-color:#e2e8f0;-fx-border-radius:10;
                                                  -fx-padding:10 14;-fx-font-size:14px;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Email Address"
                                       style="-fx-font-size:12px;-fx-font-weight:700;-fx-text-fill:#64748b;"/>
                                <TextField fx:id="emailField" promptText="your@email.com"
                                           style="-fx-background-color:#f8fafc;-fx-background-radius:10;
                                                  -fx-border-color:#e2e8f0;-fx-border-radius:10;
                                                  -fx-padding:10 14;-fx-font-size:14px;"/>
                            </VBox>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT">
                            <Button fx:id="saveNameEmailButton" text="Save Changes"
                                    onAction="#handleSaveNameEmail"
                                    style="-fx-background-color:#2E7D32;-fx-text-fill:white;
                                           -fx-background-radius:10;-fx-padding:10 28;-fx-cursor:hand;
                                           -fx-font-size:13px;-fx-font-weight:800;
                                           -fx-effect:dropshadow(gaussian,rgba(46,125,50,0.30),10,0.2,0,3);"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- ══ Change password card ══ -->
                <VBox spacing="0"
                      style="-fx-background-color:white;-fx-background-radius:16;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),20,0,0,4);">
                    <HBox style="-fx-background-color:#f8fafc;-fx-background-radius:16 16 0 0;
                                 -fx-padding:16 24;-fx-border-color:#e2e8f0;-fx-border-width:0 0 1 0;">
                        <Label text="🔒  Change Password"
                               style="-fx-font-size:15px;-fx-font-weight:800;-fx-text-fill:#0f172a;"/>
                    </HBox>
                    <VBox spacing="16" style="-fx-padding:22 24;">

                        <!-- Current password (hidden for admins) -->
                        <VBox fx:id="currentPasswordBox" spacing="6">
                            <Label text="Current Password"
                                   style="-fx-font-size:12px;-fx-font-weight:700;-fx-text-fill:#64748b;"/>
                            <PasswordField fx:id="currentPasswordField"
                                           promptText="Enter your current password"
                                           style="-fx-background-color:#f8fafc;-fx-background-radius:10;
                                                  -fx-border-color:#e2e8f0;-fx-border-radius:10;
                                                  -fx-padding:10 14;-fx-font-size:14px;"/>
                        </VBox>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="New Password"
                                       style="-fx-font-size:12px;-fx-font-weight:700;-fx-text-fill:#64748b;"/>
                                <PasswordField fx:id="newPasswordField" promptText="Min. 8 characters"
                                               style="-fx-background-color:#f8fafc;-fx-background-radius:10;
                                                      -fx-border-color:#e2e8f0;-fx-border-radius:10;
                                                      -fx-padding:10 14;-fx-font-size:14px;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Confirm New Password"
                                       style="-fx-font-size:12px;-fx-font-weight:700;-fx-text-fill:#64748b;"/>
                                <PasswordField fx:id="confirmPasswordField" promptText="Repeat new password"
                                               style="-fx-background-color:#f8fafc;-fx-background-radius:10;
                                                      -fx-border-color:#e2e8f0;-fx-border-radius:10;
                                                      -fx-padding:10 14;-fx-font-size:14px;"/>
                            </VBox>
                        </HBox>

                        <!-- inline feedback -->
                        <Label fx:id="passwordFeedbackLabel" text=""
                               style="-fx-font-size:12px;-fx-font-weight:700;" wrapText="true"/>

                        <HBox alignment="CENTER_RIGHT">
                            <Button fx:id="savePasswordButton" text="Update Password"
                                    onAction="#handleSavePassword"
                                    style="-fx-background-color:#1565C0;-fx-text-fill:white;
                                           -fx-background-radius:10;-fx-padding:10 28;-fx-cursor:hand;
                                           -fx-font-size:13px;-fx-font-weight:800;
                                           -fx-effect:dropshadow(gaussian,rgba(21,101,192,0.30),10,0.2,0,3);"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- ══ Face ID card ══ -->
                <VBox spacing="0"
                      style="-fx-background-color:white;-fx-background-radius:16;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),20,0,0,4);">
                    <HBox style="-fx-background-color:#f8fafc;-fx-background-radius:16 16 0 0;
                                 -fx-padding:16 24;-fx-border-color:#e2e8f0;-fx-border-width:0 0 1 0;">
                        <Label text="🪪  Face ID"
                               style="-fx-font-size:15px;-fx-font-weight:800;-fx-text-fill:#0f172a;"/>
                    </HBox>
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding:20 24;">
                        <StackPane style="-fx-background-color:#e3f2fd;-fx-background-radius:12;
                                         -fx-min-width:52;-fx-min-height:52;-fx-alignment:CENTER;">
                            <Label text="🪪" style="-fx-font-size:24px;"/>
                        </StackPane>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Live Face Recognition Login"
                                   style="-fx-font-size:14px;-fx-font-weight:800;-fx-text-fill:#0f172a;"/>
                            <Label fx:id="faceIdStatusLabel" text="Not set up"
                                   style="-fx-font-size:12px;-fx-text-fill:#64748b;"/>
                        </VBox>
                        <Button fx:id="faceIdButton" text="⚙  Set Up Face ID"
                                onAction="#handleSetupFaceId"
                                style="-fx-background-color:#1565C0;-fx-text-fill:white;
                                       -fx-background-radius:10;-fx-padding:10 18;-fx-cursor:hand;
                                       -fx-font-size:12px;-fx-font-weight:800;
                                       -fx-effect:dropshadow(gaussian,rgba(21,101,192,0.25),8,0.2,0,2);"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </StackPane>
</VBox>
