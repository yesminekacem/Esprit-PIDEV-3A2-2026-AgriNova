<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<!-- CONTENT-ONLY user dashboard (no sidebar/topbar) -->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.user.controller.UserDashboardController"
      style="-fx-background-color: #f5f5f5;"
      spacing="0">

    <!-- contentArea fills the available space provided by MainLayout -->
    <StackPane fx:id="contentArea" style="-fx-background-color: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">

        <!-- DEFAULT CONTENT = profile form -->
        <VBox spacing="24" alignment="TOP_CENTER" VBox.vgrow="ALWAYS" style="-fx-padding: 24;">
            <!-- white card: allow horizontal expansion -->
            <VBox alignment="TOP_CENTER" spacing="20"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 18, 0, 0, 3);"
                  VBox.vgrow="ALWAYS" maxWidth="Infinity">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <!-- Profile top: image + basic labels -->
                <HBox spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <VBox spacing="12" alignment="CENTER">
                        <ImageView fx:id="profileImageView" fitWidth="100" fitHeight="100" preserveRatio="true"
                                   style="-fx-background-radius: 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"/>
                        <Button fx:id="changePicButton" text="Change Picture" onAction="#handleChangePicture" styleClass="btn-ghost"/>
                    </VBox>

                    <VBox spacing="6" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                        <Label fx:id="welcomeLabel" text="Welcome Back!" style="-fx-font-weight: bold; -fx-font-size: 22px;"/>
                        <Label fx:id="nameLabel" text="User Name" style="-fx-font-weight: 600; -fx-font-size: 16px; -fx-text-fill: #2E7D32;"/>
                        <HBox spacing="12">
                            <VBox spacing="4" style="-fx-background-color: #f5f5f5; -fx-padding: 8; -fx-background-radius: 8;">
                                <Label text="📧" />
                                <Label fx:id="emailValueLabel" text="user@email.com" />
                            </VBox>
                            <VBox spacing="4" style="-fx-background-color: #f5f5f5; -fx-padding: 8; -fx-background-radius: 8;">
                                <Label text="👥" />
                                <Label fx:id="roleValueLabel" text="USER" />
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Editable form -->
                <GridPane hgap="16" vgap="12">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <Label text="Full Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <TextField fx:id="fullNameField" promptText="Full name" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <TextField fx:id="emailField" promptText="Email" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Password:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <PasswordField fx:id="passwordField" promptText="Leave blank to keep current" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <HBox spacing="12" alignment="CENTER_RIGHT" GridPane.rowIndex="3" GridPane.columnIndex="1">
                        <Button fx:id="saveProfileButton" text="Save Profile" onAction="#handleSaveProfile" styleClass="btn-primary"/>
                    </HBox>
                </GridPane>
            </VBox>
        </VBox>

    </StackPane>
</VBox>
