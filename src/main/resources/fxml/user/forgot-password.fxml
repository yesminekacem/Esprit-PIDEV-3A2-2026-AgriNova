<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.user.controller.ForgotPasswordController"
      prefWidth="400" prefHeight="250" spacing="20"
      style="-fx-background-color: #f8f9fa; -fx-background-radius: 12;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <VBox spacing="10" alignment="CENTER">
        <Label text="🔑" style="-fx-font-size: 36px;"/>
        <Label text="Forgot Password" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;"/>
        <Label text="Enter your email address and we'll send you a reset code:"
               style="-fx-text-fill: #555; -fx-text-alignment: center;" wrapText="true"/>
    </VBox>

    <!-- Email input -->
    <VBox spacing="8">
        <Label text="Email Address:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="emailField" promptText="Enter your email address"
                   style="-fx-font-size: 14px;" prefWidth="300"/>
        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #d32f2f; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Action buttons -->
    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="sendCodeButton" text="Send Reset Code" onAction="#handleSendResetCode"
                style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"
                prefWidth="140"/>
        <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel"
                style="-fx-background-color: #666; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"
                prefWidth="80"/>
    </HBox>

    <Label text="Remember your password? Go back to login."
           style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-text-alignment: center;"
           wrapText="true"/>

</VBox>
