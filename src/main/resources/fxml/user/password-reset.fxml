<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.user.controller.PasswordResetController"
      prefWidth="400" prefHeight="350" spacing="20"
      style="-fx-background-color: #f8f9fa; -fx-background-radius: 12;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <VBox spacing="10" alignment="CENTER">
        <Label text="🔒" style="-fx-font-size: 36px;"/>
        <Label text="Reset Password" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;"/>
        <Label text="Enter your new password below:"
               style="-fx-text-fill: #555; -fx-text-alignment: center;" wrapText="true"/>
    </VBox>

    <!-- Email display -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Email:" style="-fx-font-weight: bold;"/>
        <Label fx:id="emailLabel" text="user@example.com" style="-fx-text-fill: #2E7D32;"/>
    </HBox>

    <!-- Password fields -->
    <VBox spacing="15">
        <!-- New Password Field -->
        <VBox spacing="8">
            <Label text="New Password:" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="newPasswordField" promptText="Enter new password"
                           style="-fx-font-size: 14px;" prefWidth="300"/>
            <ProgressBar fx:id="passwordStrengthBar" prefWidth="300" progress="0"/>
            <Label fx:id="passwordStrengthLabel" text="" style="-fx-font-size: 12px;"/>
        </VBox>

        <!-- Confirm Password Field -->
        <VBox spacing="8">
            <Label text="Confirm New Password:" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password"
                           style="-fx-font-size: 14px;" prefWidth="300"/>
        </VBox>

        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #d32f2f; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Action buttons -->
    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="resetButton" text="Reset Password" onAction="#handleResetPassword"
                style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"
                prefWidth="140"/>
        <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel"
                style="-fx-background-color: #666; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"
                prefWidth="80"/>
    </HBox>

    <!-- Password requirements -->
    <VBox spacing="5">
        <Label text="Password Requirements:" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <Label text="• At least 8 characters long" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
        <Label text="• Contains uppercase and lowercase letters" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
        <Label text="• Contains at least one number" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
        <Label text="• Contains at least one special character" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
    </VBox>

</VBox>
