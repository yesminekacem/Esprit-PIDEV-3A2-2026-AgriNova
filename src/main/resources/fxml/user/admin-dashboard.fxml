<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.user.controller.AdminDashboardController"
            styleClass="app-root"
            stylesheets="@/styles/styles.css"
            prefWidth="1200" prefHeight="700">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260">

            <!-- Logo -->
            <HBox styleClass="sidebar-header" spacing="12">
                <StackPane styleClass="logo-badge">
                    <Label text="🍃" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="AgriNova" styleClass="logo-title"/>
                    <Label text="Admin Panel" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox styleClass="nav" spacing="6">
                <Button text="Users" styleClass="nav-item" onAction="#openAdminUsers"/>
                <Button text="Crops" styleClass="nav-item" onAction="#handleManageCrops"/>
                <Button text="Inventory" styleClass="nav-item"/>
                <Button text="Marketplace" styleClass="nav-item" onAction="#openMarketplace"/>
                <!-- add more later -->
                <Button text="Forum" styleClass="nav-item" onAction="#openForum"/>
                <Button text="Settings" styleClass="nav-item" onAction="#openSettings"/>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom Card -->
            <VBox styleClass="pro-card" spacing="10">
                <HBox spacing="10">
                    <StackPane styleClass="pro-icon">
                        <Label text="🌱"/>
                    </StackPane>
                    <VBox>
                        <Label text="Admin Tools" styleClass="pro-title"/>
                        <Label text="Manage users and platform settings"
                               wrapText="true"
                               styleClass="pro-text"/>
                    </VBox>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" spacing="12" alignment="CENTER_LEFT">

            <!-- Admin profile section -->
            <HBox spacing="10" alignment="CENTER" styleClass="topbar-profile">
                <StackPane styleClass="topbar-avatar">
                    <Label text="🛡" style="-fx-font-size: 18px;"/>
                </StackPane>
                <VBox spacing="1" alignment="CENTER_LEFT">
                    <Label fx:id="adminNameLabel" text="Admin User"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Label text="Administrator"
                           style="-fx-font-size: 11px; -fx-text-fill: #2E7D32;"/>
                </VBox>
            </HBox>

            <!-- Divider -->
            <Separator orientation="VERTICAL" style="-fx-padding: 4 0;"/>

            <!-- Settings -->
            <Button text="⚙ Settings" onAction="#openSettings" styleClass="topbar-action-btn"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Logout -->
            <Button fx:id="logoutButton" text="⏻ Logout" onAction="#handleLogout"
                    styleClass="topbar-logout-btn"/>

        </HBox>
    </top>

    <!-- CONTENT -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- default content will be injected by controller -->
        </StackPane>
    </center>

</BorderPane>

