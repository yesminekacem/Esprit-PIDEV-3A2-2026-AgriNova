<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.user.controller.AdminDashboardController"
            styleClass="app-root"
            stylesheets="@/styles/styles.css"
            prefWidth="1200" prefHeight="700">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260">

            <!-- Logo -->
            <HBox styleClass="sidebar-header" spacing="12">
                <StackPane styleClass="logo-badge">
                    <Label text="🍃" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="Digital Farm" styleClass="logo-title"/>
                    <Label text="Admin Panel" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox styleClass="nav" spacing="6">
                <Button text="Dashboard" styleClass="nav-item" onAction="#openAdminDashboard"/>
                <Button text="Users" styleClass="nav-item" onAction="#openAdminUsers"/>

                <!-- add more later -->
                <Button text="Forum" styleClass="nav-item" onAction="#openForum"/>
                <Button text="Settings" styleClass="nav-item"/>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bottom Card -->
            <VBox styleClass="pro-card" spacing="10">
                <HBox spacing="10">
                    <StackPane styleClass="pro-icon">
                        <Label text="🌱"/>
                    </StackPane>
                    <VBox>
                        <Label text="Admin Tools" styleClass="pro-title"/>
                        <Label text="Manage users and platform settings"
                               wrapText="true"
                               styleClass="pro-text"/>
                    </VBox>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" spacing="16" alignment="CENTER_LEFT">

            <!-- Search (optional UI only) -->
            <HBox styleClass="search-wrap" spacing="8" HBox.hgrow="ALWAYS">
                <Label text="🔍" styleClass="search-icon"/>
                <TextField promptText="Search users, roles..."
                           styleClass="search-input"
                           HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Admin name -->
            <VBox spacing="2" alignment="CENTER_RIGHT">
                <Label fx:id="adminNameLabel" text="Admin User"
                       style="-fx-font-weight: 700;"/>
                <Label text="Administrator" style="-fx-text-fill: #2E7D32;"/>
            </VBox>

            <!-- Logout -->
            <Button fx:id="logoutButton"
                    text="Logout"
                    onAction="#handleLogout"
                    styleClass="icon-btn"/>
        </HBox>
    </top>

    <!-- CONTENT -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- default content will be injected by controller -->
        </StackPane>
    </center>

</BorderPane>

