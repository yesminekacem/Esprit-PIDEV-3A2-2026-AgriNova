<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.user.controller.AdminDashboardController"
            styleClass="cream-background" prefWidth="1200" prefHeight="700"
            stylesheets="@/styles/styles.css">


    <!-- Top Bar -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <!-- Logo -->
            <StackPane style="-fx-background-color: linear-gradient(to bottom right, #2E7D32, #66BB6A); -fx-background-radius: 10; -fx-pref-width: 45; -fx-pref-height: 45;">
                <Label text="🌿" style="-fx-font-size: 22px;"/>
            </StackPane>

            <!-- Title -->
            <VBox spacing="2">
                <Label text="Digital Farm" style="-fx-font-family: 'System'; -fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1a1a1a;"/>
                <Label text="Admin Dashboard" style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- User Info -->
            <VBox spacing="2" alignment="CENTER_RIGHT">
                <Label fx:id="adminNameLabel" text="Admin User"
                       style="-fx-font-family: 'System'; -fx-font-weight: 600; -fx-font-size: 14px; -fx-text-fill: #1a1a1a;"/>
                <Label text="Administrator" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Logout Button -->
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #f5f5f5; -fx-text-fill: #666666; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- Header -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="User Management"
                       style="-fx-font-family: 'System'; -fx-font-weight: bold; -fx-font-size: 24px; -fx-text-fill: #1a1a1a;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="refreshButton" text="🔄 Refresh" onAction="#handleRefresh"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Table Container -->
            <VBox spacing="15" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 2);">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Table -->
                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-table-cell-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="80" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="nameColumn" text="Full Name" prefWidth="200"/>
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="250"/>
                        <TableColumn fx:id="roleColumn" text="Role" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- Action Buttons -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="updateButton" text="✏ Update Selected" onAction="#handleUpdate"
                            style="-fx-background-color: #FFA726; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold;"/>

                    <Button fx:id="deleteButton" text="🗑 Delete Selected" onAction="#handleDelete"
                            style="-fx-background-color: #EF5350; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
