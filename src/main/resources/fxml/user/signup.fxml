<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.user.controller.SignupController"
      minWidth="800" minHeight="600"
      stylesheets="@/styles/styles.css">

    <!-- Left Side - Illustration -->
    <VBox alignment="CENTER" spacing="30" styleClass="green-gradient"
          prefWidth="504" minWidth="320" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="60" right="50" bottom="60" left="50"/>
        </padding>

        <Label text="🌱" style="-fx-font-size: 100px;"/>

        <Label text="Join Our Community" styleClass="welcome-title"
               wrapText="true" maxWidth="400" alignment="CENTER"/>

        <Label text="Start your digital farming journey&#10;Connect with thousands of farmers"
               styleClass="welcome-subtitle" wrapText="true" maxWidth="380" alignment="CENTER"/>
    </VBox>

    <!-- Right Side - Signup Form -->
    <VBox alignment="CENTER" styleClass="cream-background"
          prefWidth="696" minWidth="420" HBox.hgrow="ALWAYS">

        <StackPane alignment="CENTER"
                   style="-fx-background-color: transparent;">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <VBox alignment="CENTER" spacing="25" styleClass="login-card"
                  maxWidth="450" minWidth="360"
                  StackPane.alignment="CENTER">

                <!-- Logo -->
                <StackPane styleClass="logo-box">
                    <Label text="🌿" style="-fx-font-size: 35px;"/>
                </StackPane>

                <!-- Title -->
                <VBox alignment="CENTER" spacing="8">
                    <Label text="Create Account" styleClass="title"/>
                    <Label text="Join the AgriNova community today" styleClass="subtitle"/>
                </VBox>

                <!-- Form -->
                <VBox spacing="20" alignment="CENTER_LEFT">

                    <!-- Full Name Field -->
                    <VBox spacing="8">
                        <Label text="Full Name" styleClass="form-label"/>
                        <StackPane alignment="CENTER_LEFT">
                            <TextField fx:id="fullNameField" promptText="John Doe"
                                       styleClass="custom-text-field" prefWidth="400"/>
                            <Label text="👤" style="-fx-font-size: 18px; -fx-padding: 0 0 0 12;"/>
                        </StackPane>
                    </VBox>

                    <!-- Email Field -->
                    <VBox spacing="8">
                        <Label text="Email Address" styleClass="form-label"/>
                        <StackPane alignment="CENTER_LEFT">
                            <TextField fx:id="emailField" promptText="farmer@example.com"
                                       styleClass="custom-text-field" prefWidth="400"/>
                            <Label text="✉" style="-fx-font-size: 18px; -fx-padding: 0 0 0 12;"/>
                        </StackPane>
                    </VBox>

                    <!-- Password Field -->
                    <VBox spacing="8">
                        <Label text="Password" styleClass="form-label"/>
                        <StackPane alignment="CENTER_LEFT" prefWidth="400">
                            <PasswordField fx:id="passwordField" promptText="••••••••"
                                           styleClass="custom-text-field" prefWidth="400"/>
                            <TextField fx:id="passwordVisible" promptText="••••••••"
                                       styleClass="custom-text-field" prefWidth="400" visible="false" managed="false"/>
                            <Label text="🔒" style="-fx-font-size: 18px; -fx-padding: 0 0 0 12;"/>
                            <Button fx:id="togglePasswordBtn" text="👁" onAction="#togglePassword"
                                    style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-cursor: hand; -fx-font-size: 16px; -fx-padding: 0 10 0 0;"
                                    StackPane.alignment="CENTER_RIGHT"/>
                        </StackPane>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <ProgressBar fx:id="passwordStrengthBar" prefWidth="200" prefHeight="6"
                                         progress="0" style="-fx-accent: #EF5350;"/>
                            <Label fx:id="passwordStrengthLabel"
                                   style="-fx-text-fill: #666666; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="passwordErrorLabel" text=""
                               style="-fx-text-fill: #EF5350; -fx-font-size: 11px; -fx-font-weight: bold;"
                               wrapText="true" maxWidth="400" managed="false" visible="false"/>
                    </VBox>

                    <!-- Confirm Password Field -->
                    <VBox spacing="8">
                        <Label text="Confirm Password" styleClass="form-label"/>
                        <StackPane alignment="CENTER_LEFT" prefWidth="400">
                            <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                                           styleClass="custom-text-field" prefWidth="400"/>
                            <TextField fx:id="confirmPasswordVisible" promptText="••••••••"
                                       styleClass="custom-text-field" prefWidth="400" visible="false" managed="false"/>
                            <Label text="🔒" style="-fx-font-size: 18px; -fx-padding: 0 0 0 12;"/>
                            <Button fx:id="toggleConfirmPasswordBtn" text="👁" onAction="#toggleConfirmPassword"
                                    style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-cursor: hand; -fx-font-size: 16px; -fx-padding: 0 10 0 0;"
                                    StackPane.alignment="CENTER_RIGHT"/>
                        </StackPane>
                        <Label fx:id="confirmPasswordErrorLabel" text=""
                               style="-fx-text-fill: #EF5350; -fx-font-size: 11px; -fx-font-weight: bold;"
                               wrapText="true" maxWidth="400" managed="false" visible="false"/>
                    </VBox>

                    <!-- Signup Button -->
                    <Button fx:id="signupButton" text="Create Account →" onAction="#handleSignup"
                            styleClass="primary-button" prefWidth="400"/>
                </VBox>

                <!-- Sign In Link -->
                <HBox spacing="5" alignment="CENTER">
                    <Label text="Already have an account?" style="-fx-text-fill: #666666; -fx-font-size: 13px;"/>
                    <Hyperlink fx:id="loginLink" text="Sign in" onAction="#handleLoginLink"
                               styleClass="link-text"/>
                </HBox>

                <!-- Terms -->
                <Label text="By creating account, you agree to our Terms of Service and Privacy Policy"
                       style="-fx-text-fill: #999999; -fx-font-size: 11px;"
                       wrapText="true" maxWidth="400" alignment="CENTER"/>
            </VBox>
        </StackPane>
    </VBox>
</HBox>
