<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.user.controller.LoginController"
      prefWidth="1400" prefHeight="800"
      stylesheets="@/styles/styles.css">

    <!-- Left Side - Illustration -->
    <VBox alignment="CENTER" spacing="30" styleClass="green-gradient" prefWidth="600">
        <padding>
            <Insets top="60" right="60" bottom="60" left="60"/>
        </padding>

        <Label text="🌾" style="-fx-font-size: 120px;"/>

        <Label text="Digital Farm Management" styleClass="welcome-title"
               wrapText="true" maxWidth="450" alignment="CENTER"/>

        <Label text="Grow smarter, harvest better,&#10;connect with farmers worldwide"
               styleClass="welcome-subtitle" wrapText="true" maxWidth="400" alignment="CENTER"/>
    </VBox>

    <!-- Right Side - Login Form -->
    <VBox alignment="CENTER" styleClass="cream-background" prefWidth="600">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <VBox alignment="CENTER" spacing="25" styleClass="login-card" maxWidth="450">

            <!-- Logo -->
            <StackPane styleClass="logo-box">
                <Label text="🌿" style="-fx-font-size: 35px;"/>
            </StackPane>

            <!-- Title -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="Welcome Back" styleClass="title"/>
                <Label text="Sign in to your Digital Farm account" styleClass="subtitle"/>
            </VBox>

            <!-- Form -->
            <VBox spacing="20" alignment="CENTER_LEFT">

                <!-- Email Field -->
                <VBox spacing="8">
                    <Label text="Email Address" styleClass="form-label"/>
                    <StackPane alignment="CENTER_LEFT">
                        <TextField fx:id="emailField" promptText="farmer@example.com"
                                   styleClass="custom-text-field" prefWidth="400"/>
                        <Label text="✉" style="-fx-font-size: 18px; -fx-padding: 0 0 0 12;"/>
                    </StackPane>
                </VBox>

                <!-- Password Field -->
                <VBox spacing="8">
                    <Label text="Password" styleClass="form-label"/>
                    <StackPane alignment="CENTER_LEFT">
                        <PasswordField fx:id="passwordField" promptText="••••••••"
                                       styleClass="custom-text-field" prefWidth="400"/>
                        <Label text="🔒" style="-fx-font-size: 18px; -fx-padding: 0 0 0 12;"/>
                    </StackPane>
                </VBox>

                <!-- Remember Me & Forgot Password -->
                <HBox spacing="10" alignment="CENTER_LEFT" prefWidth="400">
                    <CheckBox fx:id="rememberMeCheckbox" text="Remember me" styleClass="check-box"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Forgot password?" styleClass="secondary-button" onAction="#handleForgotPasswordLink" />
                </HBox>

                <!-- Login Button -->
                <Button fx:id="loginButton" text="Sign In →" onAction="#handleLogin"
                        styleClass="primary-button" prefWidth="400"/>

                <!-- Divider -->
                <HBox spacing="10" alignment="CENTER" prefWidth="400">
                    <Region HBox.hgrow="ALWAYS"
                            style="-fx-border-color:#e0e0e0;-fx-border-width:1 0 0 0;"/>
                    <Label text="or" style="-fx-text-fill:#9ca3af;-fx-font-size:12px;"/>
                    <Region HBox.hgrow="ALWAYS"
                            style="-fx-border-color:#e0e0e0;-fx-border-width:1 0 0 0;"/>
                </HBox>

                <!-- Face ID Login Button -->
                <Button text="🪪   Login with Face ID" onAction="#handleFaceLogin"
                        prefWidth="400"
                        style="-fx-background-color:#1565C0;-fx-text-fill:white;
                               -fx-background-radius:10;-fx-padding:12 0;-fx-cursor:hand;
                               -fx-font-size:14px;-fx-font-weight:700;
                               -fx-effect:dropshadow(gaussian,rgba(21,101,192,0.25),10,0.2,0,3);"/>
            </VBox>


            <!-- Sign Up Link -->
            <HBox spacing="5" alignment="CENTER">
                <Label text="Don't have an account?" style="-fx-text-fill: #666666; -fx-font-size: 13px;"/>
                <Hyperlink fx:id="signupLink" text="Create account" onAction="#handleSignupLink"
                           styleClass="link-text"/>
            </HBox>

            <!-- Terms -->
            <Label text="By signing in, you agree to our Terms of Service and Privacy Policy"
                   style="-fx-text-fill: #999999; -fx-font-size: 11px;"
                   wrapText="true" maxWidth="400" alignment="CENTER"/>
        </VBox>
    </VBox>
</HBox>
