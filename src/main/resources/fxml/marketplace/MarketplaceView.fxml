<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.marketplace.controller.MarketplaceController"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header with User Info -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 0 24 0;">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Marketplace" styleClass="page-title"/>
        </VBox>
    </HBox>

    <!-- Tab Navigation -->
    <HBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 8 8 0 0; -fx-border-color: #e5e7eb; -fx-border-width: 1 1 0 1; -fx-border-radius: 8 8 0 0;">
        <Button fx:id="btnMarketplace" text="Marketplace" onAction="#showMarketplace"
                styleClass="primary-button" HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnManageProducts" text="Manage Products" onAction="#showManageProducts"
                styleClass="secondary-button" HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnCart" text="Cart" onAction="#showCart"
                styleClass="secondary-button" HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Content Area (Empty containers - views loaded dynamically) -->
    <StackPane VBox.vgrow="ALWAYS">
        <VBox fx:id="marketplaceTab" visible="true"
              style="-fx-background-color: white; -fx-background-radius: 0 0 8 8; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 1 1; -fx-border-radius: 0 0 8 8;"/>

        <VBox fx:id="manageProductsTab" visible="false"
              style="-fx-background-color: white; -fx-background-radius: 0 0 8 8; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 1 1; -fx-border-radius: 0 0 8 8;"/>

        <VBox fx:id="cartTab" visible="false"
              style="-fx-background-color: white; -fx-background-radius: 0 0 8 8; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 1 1; -fx-border-radius: 0 0 8 8;"/>
    </StackPane>

</VBox>