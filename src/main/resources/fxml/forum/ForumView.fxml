<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<ScrollPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.forum.controller.ForumViewController"
            fitToWidth="true"
            styleClass="page-scroll"
            stylesheets="@/styles/forum.css"
            style="-fx-background-color: transparent;">

    <content>
        <VBox spacing="18"
              prefWidth="900"
              style="-fx-padding: 18; -fx-background-color: transparent;">

            <!-- HERO HEADER CARD -->
            <VBox spacing="14"
                  style="-fx-background-color: rgba(255,255,255,0.92);
                         -fx-background-radius: 18;
                         -fx-padding: 18;
                         -fx-border-color: rgba(0,0,0,0.06);
                         -fx-border-radius: 18;">
                <effect>
                    <DropShadow color="#00000022" radius="18" offsetY="5"/>
                </effect>

                <!-- Header row -->
                <HBox alignment="CENTER_LEFT" spacing="12">

                    <VBox HBox.hgrow="ALWAYS" spacing="6">
                        <Label text="Community Forum"
                               style="-fx-font-size: 34px; -fx-font-weight: 900; -fx-text-fill: #0f172a;"/>
                        <Label text="Connect, discuss, and learn from fellow farmers"
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>

                    <!-- Notifications -->
                    <StackPane>
                        <Button fx:id="btnNotifications"
                                text="🔔"
                                onAction="#onOpenNotifications"
                                style="-fx-background-color: white;
                                       -fx-background-radius: 12;
                                       -fx-border-color: rgba(0,0,0,0.10);
                                       -fx-border-radius: 12;
                                       -fx-padding: 8 10;
                                       -fx-cursor: hand;
                                       -fx-font-size: 14px;"/>

                        <Label fx:id="lblNotifBadge"
                               text="0"
                               visible="false" managed="false"
                               StackPane.alignment="TOP_RIGHT"
                               style="-fx-background-color: #ef4444;
                                      -fx-text-fill: white;
                                      -fx-font-weight: 800;
                                      -fx-padding: 2 7;
                                      -fx-background-radius: 999;
                                      -fx-font-size: 11px;
                                      -fx-translate-x: 7;
                                      -fx-translate-y: -7;"/>
                    </StackPane>

                    <!-- New Topic -->
                    <Button text="+  New Topic"
                            onAction="#onAdd"
                            style="-fx-background-color: linear-gradient(to bottom, #22c55e, #16a34a);
                                   -fx-text-fill: white;
                                   -fx-font-weight: 800;
                                   -fx-background-radius: 14;
                                   -fx-padding: 10 16;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 16, 0, 0, 5);"/>
                </HBox>

                <!-- SEARCH ROW -->
                <HBox spacing="10" alignment="CENTER_LEFT">

                    <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 14;
                                 -fx-border-color: rgba(0,0,0,0.08);
                                 -fx-border-radius: 14;
                                 -fx-padding: 10 12;">
                        <Label text="🔎" style="-fx-opacity: 0.65; -fx-font-size: 14px;"/>

                        <TextField fx:id="txtSearch"
                                   promptText="Search by title, content, author..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-color: transparent;
                                          -fx-font-size: 13px;
                                          -fx-padding: 6 0;"/>
                    </HBox>

                    <!-- Clear pill -->
                    <Button text="✕  Clear"
                            onAction="#onClearSearch"
                            style="-fx-background-color: rgba(255,255,255,0.95);
                                   -fx-border-color: rgba(0,0,0,0.10);
                                   -fx-border-radius: 999;
                                   -fx-background-radius: 999;
                                   -fx-padding: 10 14;
                                   -fx-font-weight: 700;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- POPULAR CATEGORIES CARD -->
            <VBox spacing="12"
                  style="-fx-background-color: rgba(255,255,255,0.92);
                         -fx-background-radius: 18;
                         -fx-padding: 16;
                         -fx-border-color: rgba(0,0,0,0.06);
                         -fx-border-radius: 18;">
                <effect>
                    <DropShadow color="#00000020" radius="16" offsetY="4"/>
                </effect>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Popular Categories"
                           style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #0f172a;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Tip: click to filter"
                           style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                </HBox>

                <FlowPane hgap="10" vgap="10">

                    <!-- Chips (no code change: same onAction) -->
                    <Button text="All" onAction="#filterByCategory"
                            style="-fx-background-color: #f3e8ff; -fx-text-fill: #6b21a8;
                                   -fx-background-radius: 999; -fx-padding: 8 14;
                                   -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;"/>

                    <Button text="Organic Farming" onAction="#filterByCategory"
                            style="-fx-background-color: #e6f7e6; -fx-text-fill: #2e7d32;
                                   -fx-background-radius: 999; -fx-padding: 8 14;
                                   -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;"/>

                    <Button text="Soil Management" onAction="#filterByCategory"
                            style="-fx-background-color: #fff3e0; -fx-text-fill: #b45309;
                                   -fx-background-radius: 999; -fx-padding: 8 14;
                                   -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;"/>

                    <Button text="Water Management" onAction="#filterByCategory"
                            style="-fx-background-color: #e3f2fd; -fx-text-fill: #1e4bd2;
                                   -fx-background-radius: 999; -fx-padding: 8 14;
                                   -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;"/>

                    <Button text="Harvesting" onAction="#filterByCategory"
                            style="-fx-background-color: #ffedd5; -fx-text-fill: #c2410c;
                                   -fx-background-radius: 999; -fx-padding: 8 14;
                                   -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;"/>

                    <Button text="Equipment" onAction="#filterByCategory"
                            style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563;
                                   -fx-background-radius: 999; -fx-padding: 8 14;
                                   -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;"/>

                    <Button text="Crop Management" onAction="#filterByCategory"
                            style="-fx-background-color: #d1fae5; -fx-text-fill: #047857;
                                   -fx-background-radius: 999; -fx-padding: 8 14;
                                   -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;"/>
                </FlowPane>
            </VBox>

            <!-- TOPICS LIST HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 4;">
                <Label text="Latest Topics"
                       style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #0f172a;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Scroll to explore"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
            </HBox>

            <!-- TOPICS LIST -->
            <ListView fx:id="topicsList"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: rgba(0,0,0,0.06);
                             -fx-background-color: rgba(255,255,255,0.92);">
                <effect>
                    <DropShadow color="#00000018" radius="18" offsetY="5"/>
                </effect>
            </ListView>

            <!-- STATS -->
            <HBox spacing="14">

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(34,197,94,0.14);
                             -fx-background-radius: 18;
                             -fx-padding: 14;
                             -fx-border-color: rgba(34,197,94,0.20);
                             -fx-border-radius: 18;">
                    <Label text="Total Topics"
                           style="-fx-text-fill: #14532d; -fx-font-weight: 800;"/>
                    <Label fx:id="lblTotalTopics" text="0"
                           style="-fx-text-fill: #14532d; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(59,130,246,0.12);
                             -fx-background-radius: 18;
                             -fx-padding: 14;
                             -fx-border-color: rgba(59,130,246,0.18);
                             -fx-border-radius: 18;">
                    <Label text="Total Replies"
                           style="-fx-text-fill: #1e3a8a; -fx-font-weight: 800;"/>
                    <Label fx:id="lblTotalReplies" text="0"
                           style="-fx-text-fill: #1e3a8a; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(249,115,22,0.14);
                             -fx-background-radius: 18;
                             -fx-padding: 14;
                             -fx-border-color: rgba(249,115,22,0.20);
                             -fx-border-radius: 18;">
                    <Label text="Active Members"
                           style="-fx-text-fill: #7c2d12; -fx-font-weight: 800;"/>
                    <Label text="142"
                           style="-fx-text-fill: #7c2d12; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                </VBox>

            </HBox>

            <!-- FAB -->
            <StackPane pickOnBounds="false" alignment="BOTTOM_RIGHT">
                <Button text="＋"
                        onAction="#onAdd"
                        style="-fx-background-color: linear-gradient(to bottom, #22c55e, #16a34a);
                               -fx-text-fill: white;
                               -fx-font-size: 18px;
                               -fx-font-weight: 900;
                               -fx-background-radius: 999;
                               -fx-padding: 12 16;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 7);"/>
                <StackPane.margin>
                    <Insets top="0" right="6" bottom="12" left="0"/>
                </StackPane.margin>
            </StackPane>

        </VBox>
    </content>
</ScrollPane>