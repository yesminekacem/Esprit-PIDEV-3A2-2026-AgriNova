<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.forum.controller.EditTopicController"
            styleClass="page">

    <top>
        <VBox spacing="10" styleClass="container">
            <padding>
                <Insets top="16" right="16" bottom="10" left="16"/>
            </padding>

            <Button text="← Back"
                    onAction="#onBack"
                    styleClass="btn-ghost"/>

            <Label text="Edit Topic" styleClass="topic-title"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="container">
            <padding>
                <Insets top="10" right="16" bottom="16" left="16"/>
            </padding>

            <VBox styleClass="card">
                <VBox spacing="10" styleClass="card-content">

                    <!-- Title + counter -->
                    <Label text="Title" styleClass="muted"/>
                    <VBox spacing="4">
                        <TextField fx:id="txtTitle"
                                   promptText="Topic title"
                                   styleClass="input-field"/>
                        <Label fx:id="lblTitleCounter"
                               text="0 / 5 characters minimum"
                               styleClass="input-helper"/>
                    </VBox>

                    <!-- Category -->
                    <Label text="Category" styleClass="muted"/>
                    <ComboBox fx:id="cbCategory" promptText="Choose category"/>

                    <!-- Content + counter -->
                    <Label text="Content" styleClass="muted"/>
                    <VBox spacing="4">
                        <TextArea fx:id="txtContent"
                                  wrapText="true"
                                  prefRowCount="8"
                                  promptText="Write your topic content..."
                                  styleClass="input-area"/>
                        <Label fx:id="lblContentCounter"
                               text="0 / 20 characters minimum"
                               styleClass="input-helper"/>
                    </VBox>

                    <!-- Actions -->
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button text="Cancel" onAction="#onBack" styleClass="btn-outline"/>
                        <Button text="Save Changes" onAction="#onSave" styleClass="btn-primary"/>
                    </HBox>

                </VBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>
