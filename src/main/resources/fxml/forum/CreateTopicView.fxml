<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-padding: 20;">
    <Label text="Create Topic" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <TextField promptText="Title"/>
    <TextArea promptText="Content" prefRowCount="6"/>
    <ChoiceBox />
    <HBox spacing="10">
        <Button text="Publish"/>
        <Button text="Cancel"/>
    </HBox>
</VBox>
