<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="6" style="-fx-padding: 15;">
            <Label text="Topic title here" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="Topic content preview..." wrapText="true"/>
        </VBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label text="Comments" style="-fx-font-weight: bold;"/>
            <ListView />
            <TextField promptText="Write a comment..."/>
            <Button text="Send"/>
        </VBox>
    </center>
</BorderPane>
