<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.crop.controller.TaskController"
            style="-fx-background-color: linear-gradient(to bottom, #f5f7fa, #e4efe9); -fx-padding: 25;">

    <!-- TOP -->
    <top>
        <VBox alignment="CENTER"
              spacing="30"
              style="-fx-padding: 10 0 20 0;">

            <HBox alignment="CENTER"
                  spacing="15">

                <!-- SEARCH BAR -->
                <HBox alignment="CENTER_LEFT"
                      spacing="10"
                      prefWidth="550"
                      style="
                      -fx-background-color: white;
                      -fx-background-radius: 30;
                      -fx-padding: 12 25 12 25;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 4);
                  ">

                    <Label text="🔍"
                           style="-fx-font-size: 16px;"/>

                    <TextField fx:id="searchField"
                               promptText="Search tasks..."
                               prefWidth="450"
                               style="
                               -fx-background-color: transparent;
                               -fx-border-color: transparent;
                               -fx-font-size: 14px;
                               -fx-prompt-text-fill: #9e9e9e;
                           "/>
                </HBox>

                <!-- PDF BUTTON -->
                <Button text="📄 Export PDF"
                        onAction="#handleExportPDF"
                        style="
                        -fx-background-color: #2e7d32;
                        -fx-text-fill: white;
                        -fx-background-radius: 25;
                        -fx-padding: 10 20 10 20;
                        -fx-font-weight: bold;
                        -fx-cursor: hand;
                    "/>

            </HBox>

        </VBox>
    </top>
    <!-- CENTER KANBAN -->
    <center>
        <ScrollPane fitToWidth="true"
                    vbarPolicy="AS_NEEDED"
                    hbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent;">

            <content>
                <VBox spacing="20" style="-fx-padding: 10;">

                    <HBox spacing="25"
                          alignment="TOP_CENTER">

                        <!-- Pending -->
                        <VBox fx:id="pendingBox"
                              spacing="15"
                              prefWidth="260"
                              style="-fx-background-color: white;
                                 -fx-background-radius: 15;
                                 -fx-padding: 15;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">

                            <Label text="Pending"
                                   style="-fx-font-weight: bold;
                                      -fx-font-size: 15;
                                      -fx-text-fill: #f57c00;"/>
                        </VBox>

                        <!-- In Progress -->
                        <VBox fx:id="progressBox"
                              spacing="15"
                              prefWidth="260"
                              style="-fx-background-color: white;
                                 -fx-background-radius: 15;
                                 -fx-padding: 15;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">

                            <Label text="In Progress"
                                   style="-fx-font-weight: bold;
                                      -fx-font-size: 15;
                                      -fx-text-fill: #1976d2;"/>
                        </VBox>

                        <!-- Completed -->
                        <VBox fx:id="completedBox"
                              spacing="15"
                              prefWidth="260"
                              style="-fx-background-color: white;
                                 -fx-background-radius: 15;
                                 -fx-padding: 15;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">

                            <Label text="Completed"
                                   style="-fx-font-weight: bold;
                                      -fx-font-size: 15;
                                      -fx-text-fill: #2e7d32;"/>
                        </VBox>

                        <!-- Cancelled -->
                        <VBox fx:id="cancelledBox"
                              spacing="15"
                              prefWidth="260"
                              style="-fx-background-color: white;
                                 -fx-background-radius: 15;
                                 -fx-padding: 15;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">

                            <Label text="Cancelled"
                                   style="-fx-font-weight: bold;
                                      -fx-font-size: 15;
                                      -fx-text-fill: #c62828;"/>
                        </VBox>

                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
