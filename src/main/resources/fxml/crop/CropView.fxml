<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.chart.PieChart?>
<VBox spacing="28"
      alignment="TOP_LEFT"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.crop.controller.CropViewController"
      stylesheets="/styles/styles.css"
      prefWidth="900"
      prefHeight="600"
      style="-fx-background-color: linear-gradient(to bottom right, #f8fafc, #e8f5e9);">

    <padding>
        <Insets top="30" right="35" bottom="30" left="35"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT"
          spacing="15"
          style="-fx-padding: 0 0 10 0;">

        <Label text="Crop Management (Admin)"
               HBox.hgrow="ALWAYS"
               style="-fx-font-size: 26px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #1b5e20;" />


        <!-- Add Crop Button -->
        <Button text="+ Add Crop"
                onAction="#handleAddCrop"
                style="-fx-background-color: linear-gradient(to right, #2e7d32, #66bb6a);
                   -fx-text-fill: white;
                   -fx-font-weight: bold;
                   -fx-font-size: 14px;
                   -fx-background-radius: 30;
                   -fx-padding: 10 22;
                   -fx-cursor: hand;
                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 15, 0, 0, 5);" />
    </HBox>
    <!-- Table -->
    <TableView fx:id="cropsTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: white;
                  -fx-background-radius: 20;
                  -fx-border-radius: 20;
                  -fx-padding: 12;
                  -fx-table-cell-border-color: transparent;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 6);">

        <columns>

            <TableColumn fx:id="colName"
                         text="Crop Name"
                         prefWidth="150"
                         style="-fx-alignment: CENTER-LEFT;
                        -fx-font-size: 14px;
                        -fx-font-weight: bold;
                        -fx-text-fill: #1b5e20;" />

            <TableColumn fx:id="colType"
                         text="Type"
                         prefWidth="90"
                         style="-fx-alignment: CENTER;
                        -fx-font-weight: bold;" />

            <TableColumn fx:id="colArea"
                         text="Area"
                         prefWidth="80"
                         style="-fx-alignment: CENTER;
                        -fx-font-weight: bold;" />

            <TableColumn fx:id="colPlanted"
                         text="Planting Date"
                         prefWidth="130"
                         style="-fx-alignment: CENTER;
                        -fx-font-weight: bold;" />

            <TableColumn fx:id="colHarvest"
                         text="Harvest Date"
                         prefWidth="130"
                         style="-fx-alignment: CENTER;
                        -fx-font-weight: bold;" />

            <TableColumn fx:id="colGrowthStage"
                         text="Growth Stage"
                         prefWidth="120"
                         style="-fx-alignment: CENTER;
                        -fx-font-weight: bold;" />

            <TableColumn fx:id="colStatus"
                         text="Status"
                         prefWidth="100"
                         style="-fx-alignment: CENTER;
                        -fx-font-weight: bold;
                        -fx-text-fill: #2e7d32;" />

            <TableColumn fx:id="colAction"
                         text="Actions"
                         prefWidth="150"
                         style="-fx-alignment: CENTER;
                        -fx-font-weight: bold;" />

        </columns>


    </TableView>
    <!-- 📊 Statistics Dashboard -->
    <VBox spacing="20">

        <!-- Colored Cards -->
        <HBox spacing="25" alignment="CENTER">

            <VBox alignment="CENTER"
                  style="-fx-background-color: #e8f5e9;
                     -fx-padding: 20;
                     -fx-background-radius: 15;">
                <Label text="Total Area" style="-fx-font-weight: bold;" />
                <Label fx:id="totalAreaLabel"
                       style="-fx-font-size: 20px; -fx-text-fill: #2e7d32;" />
            </VBox>

            <VBox alignment="CENTER"
                  style="-fx-background-color: #fff3e0;
                     -fx-padding: 20;
                     -fx-background-radius: 15;">
                <Label text="Average Area" style="-fx-font-weight: bold;" />
                <Label fx:id="averageAreaLabel"
                       style="-fx-font-size: 20px; -fx-text-fill: #ef6c00;" />
            </VBox>

            <VBox alignment="CENTER"
                  style="-fx-background-color: #e3f2fd;
                     -fx-padding: 20;
                     -fx-background-radius: 15;">
                <Label text="Largest Crop" style="-fx-font-weight: bold;" />
                <Label fx:id="maxAreaLabel"
                       style="-fx-font-size: 20px; -fx-text-fill: #1565c0;" />
            </VBox>

        </HBox>

        <!-- 🔵 Circle Chart -->
        <PieChart fx:id="areaPieChart"
                  title="Area Distribution by Type"
                  legendVisible="true"
                  prefHeight="300"/>

    </VBox>






</VBox>
