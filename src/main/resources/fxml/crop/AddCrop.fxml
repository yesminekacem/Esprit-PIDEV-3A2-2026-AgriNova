<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.crop.controller.AddCropController"
      prefWidth="900"
      prefHeight="650"
      spacing="22"
      alignment="CENTER"
      stylesheets="/styles/styles.css"
      style="-fx-padding: 45;
             -fx-background-color: linear-gradient(to bottom right, #f8fafc, #e8f5e9);">

    <!-- Title -->
    <Label fx:id="lblTitle"
           text="Add New Crop"
           style="-fx-font-size: 26px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #1b5e20;
                  -fx-padding: 0 0 15 0;" />

    <!-- Fields -->
    <TextField fx:id="nameField"
               promptText="Crop name"
               style="-fx-background-color: white;
                      -fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-border-color: #cfd8dc;
                      -fx-padding: 12;" />

    <TextField fx:id="typeField"
               promptText="Type (e.g. Vegetable)"
               style="-fx-background-color: white;
                      -fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-border-color: #cfd8dc;
                      -fx-padding: 12;" />

    <TextField fx:id="varietyField"
               promptText="Variety"
               style="-fx-background-color: white;
                      -fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-border-color: #cfd8dc;
                      -fx-padding: 12;" />

    <DatePicker fx:id="plantingDatePicker"
                promptText="Planting date"
                style="-fx-background-color: white;
                       -fx-background-radius: 12;
                       -fx-border-radius: 12;
                       -fx-border-color: #cfd8dc;" />

    <DatePicker fx:id="harvestDatePicker"
                promptText="Expected harvest date"
                style="-fx-background-color: white;
                       -fx-background-radius: 12;
                       -fx-border-radius: 12;
                       -fx-border-color: #cfd8dc;" />

    <TextField fx:id="growthStageField"
               promptText="Growth stage"
               style="-fx-background-color: white;
                      -fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-border-color: #cfd8dc;
                      -fx-padding: 12;" />

    <TextField fx:id="areaField"
               promptText="Area size (e.g. 12.5)"
               style="-fx-background-color: white;
                      -fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-border-color: #cfd8dc;
                      -fx-padding: 12;" />

    <ComboBox fx:id="statusCombo"
              promptText="Status"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-border-radius: 12;
                     -fx-border-color: #cfd8dc;">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="planned"/>
                <String fx:value="active"/>
                <String fx:value="harvested"/>
                <String fx:value="failed"/>
            </FXCollections>
        </items>
    </ComboBox>

    <!-- Image Section -->
    <VBox spacing="10"
          alignment="CENTER"
          style="-fx-background-color: white;
                 -fx-background-radius: 15;
                 -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 4);">

        <Button text="Choose Image"
                onAction="#handleChooseImage"
                style="-fx-background-color: linear-gradient(to right, #1565c0, #42a5f5);
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 25;
                       -fx-padding: 10 20;
                       -fx-cursor: hand;" />

        <Label fx:id="imageLabel"
               text="No image selected"
               style="-fx-text-fill: #78909c;
                      -fx-font-size: 13px;" />
    </VBox>

    <!-- Buttons -->
    <HBox spacing="18" alignment="CENTER">

        <Button text="Save"
                onAction="#handleSave"
                style="-fx-background-color: linear-gradient(to right, #2e7d32, #66bb6a);
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 14px;
                       -fx-background-radius: 30;
                       -fx-padding: 12 30;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 15, 0, 0, 5);" />

        <Button text="Cancel"
                onAction="#handleCancel"
                style="-fx-background-color: white;
                       -fx-border-color: #b0bec5;
                       -fx-border-width: 2;
                       -fx-text-fill: #455a64;
                       -fx-font-weight: bold;
                       -fx-background-radius: 30;
                       -fx-border-radius: 30;
                       -fx-padding: 12 30;
                       -fx-cursor: hand;" />
    </HBox>

</VBox>
